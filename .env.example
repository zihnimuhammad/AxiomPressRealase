# Copy to .env for local dev: cp .env.example .env

# Postgres connection used by Prisma
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/press_release_dist?schema=public"

# NextAuth — generate a secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# Seeded users — overridable for deploys (defaults are demo). Passwords are
# bcrypt-hashed at seed time; re-running the seed upserts (never wipes) data.
SEED_SUPERADMIN_EMAIL="admin@axiompr.com"
SEED_SUPERADMIN_PASSWORD="admin123"
SEED_STAFF_EMAIL="staff@prdist.com"
SEED_STAFF_PASSWORD="staff123"
SEED_USER_EMAIL="budi@gmail.com"
SEED_USER_PASSWORD="user123"
